		{
			"name": "[concat(parameters('factoryName'), '/df_silver_orders_transform')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_orders_csv",
								"type": "DatasetReference"
							},
							"name": "OrdersSource"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_silver_orders_output",
								"type": "DatasetReference"
							},
							"name": "SilverSink"
						}
					],
					"transformations": [
						{
							"name": "FilterNulls"
						},
						{
							"name": "AddColumns"
						},
						{
							"name": "AggregateOrders"
						}
					],
					"scriptLines": [
						"source(output(",
						"          order_id as string,",
						"          customer_id as string,",
						"          order_status as string,",
						"          order_purchase_timestamp as string,",
						"          order_approved_at as string,",
						"          order_delivered_carrier_date as string,",
						"          order_delivered_customer_date as string,",
						"          order_estimated_delivery_date as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> OrdersSource",
						"OrdersSource filter( !isNull(order_id) && !isNull(customer_id)) ~> FilterNulls",
						"FilterNulls derive(order_year = year(toTimestamp(order_purchase_timestamp)),",
						"          order_month = month(toTimestamp(order_purchase_timestamp)),",
						"          fulfillment_days = toInteger(0)) ~> AddColumns",
						"AddColumns aggregate(groupBy(customer_id,",
						"          order_status),",
						"     total_orders = count(order_id),",
						"          avg_fulfillment = avg(fulfillment_days)) ~> AggregateOrders",
						"AggregateOrders sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['orders_silver.csv'],",
						"     truncate: true,",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> SilverSink"
					]
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_orders_csv')]",
				"[concat(variables('factoryId'), '/datasets/ds_silver_orders_output')]"
			]
		}
	]
